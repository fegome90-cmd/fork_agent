{
  "version": "1.0",
  "description": "Hooks de integración para fork_agent - Fase 1 (tmux + memory)",
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": ".hooks/workspace-init.sh",
            "timeout": 5,
            "critical": true,
            "on_failure": "abort"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": ".hooks/tmux-session-per-agent.sh",
            "timeout": 10,
            "critical": true,
            "on_failure": "abort"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": ".hooks/memory-trace-writer.sh",
            "timeout": 5,
            "critical": false,
            "on_failure": "continue"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash.*git.*",
        "hooks": [
          {
            "type": "command",
            "command": ".hooks/git-branch-guard.sh",
            "timeout": 1,
            "critical": true,
            "on_failure": "abort"
          }
        ]
      }
    ]
  }
}
