{
  "agent_metrics": {
    "interval": 30,
    "enabled": true
  },
  "circuit_breaker": {
    "failure_threshold": 5,
    "recovery_timeout": 60,
    "half_open_max_calls": 3
  },
  "ipc": {
    "max_retries": 3,
    "timeout": 30,
    "dead_letter_queue_size": 1000
  },
  "tmux": {
    "session_prefix": "fork-agent",
    "default_timeout": 300
  }
}
